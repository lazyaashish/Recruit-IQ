# ── RecruitIQ Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.

# Security — REQUIRED: generate a strong random string (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-long-random-string

# Database — SQLite for local dev; use a hosted Postgres URL for production
# Example Postgres: postgresql://user:pass@host:5432/recruitiq
DATABASE_URL=sqlite:///./recruitiq.db

# App environment
ENVIRONMENT=production

# CORS — comma-separated list of allowed frontend origins
# Example: https://recruitiq.vercel.app,https://your-custom-domain.com
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# Optional: LLM enrichment (leave blank to use rule-based fallback)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Frontend (Vite) — set this to your Vercel backend URL during local dev
# In production on Vercel the frontend proxies through the same domain so this
# can be left unset (defaults to /api/v1).
# VITE_API_URL=https://your-project.vercel.app/api/v1
