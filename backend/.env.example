# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=RecruitIQ
DEBUG=false
ENVIRONMENT=development

# ── Security — CHANGE THIS IN PRODUCTION ─────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev)
DATABASE_URL=sqlite:///./recruitiq.db
# PostgreSQL (production) — uncomment and fill:
# DATABASE_URL=postgresql://user:password@localhost:5432/recruitiq

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── Optional LLM (leave blank to use deterministic mode only) ─────────────────
# LLM_PROVIDER=openai        # openai | anthropic
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=              # custom endpoint (e.g. local Ollama)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
