{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "/api/index.py" },
    { "src": "/api/(.*)",    "dest": "/api/index.py" },
    { "src": "/health",      "dest": "/api/index.py" },
    { "src": "/docs",        "dest": "/api/index.py" },
    { "src": "/redoc",       "dest": "/api/index.py" },
    {
      "src": "/(.*\\.(?:js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot|map|webp|avif))",
      "dest": "/$1"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "ENVIRONMENT": "production",
    "DATABASE_URL": "sqlite:////tmp/recruitiq.db"
  }
}
